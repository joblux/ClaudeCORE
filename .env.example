# ═══════════════════════════════════════════════════
# JOBLUX — Environment Variables
# Copy to .env.local for development
# Add to Vercel for production
# ═══════════════════════════════════════════════════

# ── Supabase (already set) ──
NEXT_PUBLIC_SUPABASE_URL=https://zspcmvdoqhvrcdynlriz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ──
NEXTAUTH_URL=https://www.luxuryrecruiter.com
NEXTAUTH_SECRET=your-nextauth-secret

# ── LinkedIn OAuth ──
# Get from: https://www.linkedin.com/developers/apps
# Callback URL: https://www.luxuryrecruiter.com/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Google OAuth ──
# Get from: https://console.cloud.google.com/apis/credentials
# Callback URL: https://www.luxuryrecruiter.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AWS SES (Email) ──
# Region: eu-west-1, verified domain: joblux.com
AWS_SES_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=

# ── Unsplash (WikiLux images) ──
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Vercel Cron ──
CRON_SECRET=your_cron_secret
